---
import FormattedDate from '../components/FormattedDate.astro';
import SiteLayout from './SiteLayout.astro';

interface Props {
	title: string;
	description: string;
	pubDate?: Date;
	updatedDate?: Date;
}

const { title, description, pubDate, updatedDate } = Astro.props;
---

<SiteLayout
	title={title}
	description={description}
	type="article"
	publishedDate={pubDate}
	updatedDate={updatedDate}
>
	<article class="article-shell">
		<a class="back-link" href="/blog">← Notes</a>

		<header class="article-header">
			<h1>{title}</h1>
			{description && <p class="article-description">{description}</p>}
			{pubDate && (
				<p class="article-date"><FormattedDate date={pubDate} /></p>
			)}
			{updatedDate && (
				<p class="updated-date">Updated <FormattedDate date={updatedDate} /></p>
			)}
		</header>

		<div class="prose">
			<slot />
		</div>
	</article>
</SiteLayout>

<style>
	.article-shell {
		width: min(100%, 42rem);
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		margin-left: -0.65rem;
		padding: 0.45rem 0.65rem;
		border-radius: 999px;
		background: transparent;
		color: var(--muted-foreground);
		font-size: 0.88rem;
		font-weight: 570;
		text-decoration: none;
		transition: background-color 140ms ease, color 140ms ease;
	}

	.back-link:hover,
	.back-link:focus-visible {
		background: rgb(128 128 128 / 14%);
		color: var(--foreground);
	}

	.article-header {
		padding: clamp(2.5rem, 7vw, 4.5rem) 0 clamp(2rem, 5vw, 3.25rem);
	}

	h1 {
		max-width: 40rem;
		margin: 0;
		font-size: clamp(2.75rem, 8vw, 4.75rem);
		font-weight: 610;
		letter-spacing: -0.06em;
		line-height: 0.98;
	}

	.article-description {
		max-width: 34rem;
		margin: 1.2rem 0 0;
		color: var(--muted-foreground);
		font-size: 1.05rem;
		line-height: 1.55;
	}

	.article-date,
	.updated-date {
		margin: 1.1rem 0 0;
		color: var(--muted-foreground);
		font-size: 0.82rem;
	}

	.updated-date {
		margin-top: 0.25rem;
	}

</style>
