---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE_TITLE } from '../consts';

interface Props {
	title: string;
	description: string;
	type?: 'website' | 'article';
	publishedDate?: Date;
	updatedDate?: Date;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	description,
	type = 'website',
	publishedDate,
	updatedDate,
} = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<title>{SITE_TITLE}</title>
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="color-scheme" content="light dark" />
<meta name="theme-color" content="#f7f6f2" data-theme-color />
<script is:inline>
	(() => {
		const userAgent = navigator.userAgent;
		const isIOS = /iP(?:ad|hone|od)/.test(userAgent)
			|| (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
		const supportsBackdrop = typeof CSS !== 'undefined' && (
			CSS.supports('-webkit-backdrop-filter', 'blur(1px)')
			|| CSS.supports('backdrop-filter', 'blur(1px)')
		);
		const useIOSGlass = isIOS && /AppleWebKit/i.test(userAgent) && supportsBackdrop;
		const applyDocumentPreferences = () => {
			const root = document.documentElement;
			root.toggleAttribute('data-ios-webkit', useIOSGlass);

			const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches
				? 'dark'
				: 'light';
			let theme = systemTheme;

			try {
				const savedTheme = window.localStorage.getItem('shen.zip-theme');
				if (savedTheme === 'light' || savedTheme === 'dark') {
					theme = savedTheme;
					root.dataset.theme = savedTheme;
				}
			} catch {}

			document.querySelector('[data-theme-color]')?.setAttribute(
				'content',
				theme === 'dark' ? '#111211' : '#f7f6f2',
			);
		};

		applyDocumentPreferences();
		if (!window.__shenDocumentPreferences) {
			window.__shenDocumentPreferences = true;
			document.addEventListener('astro:after-swap', applyDocumentPreferences);
		}
	})();
</script>
<ClientRouter fallback="swap" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={SITE_TITLE} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content={SITE_TITLE} />
{type === 'article' && publishedDate && (
	<meta property="article:published_time" content={publishedDate.toISOString()} />
)}
{type === 'article' && updatedDate && (
	<meta property="article:modified_time" content={updatedDate.toISOString()} />
)}

<!-- Twitter -->
<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={SITE_TITLE} />
<meta name="twitter:description" content={description} />
