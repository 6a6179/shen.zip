---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = Astro.url.pathname.replace(base, '').replace(/\/$/, '') || '/';
const normalizedHref = typeof href === 'string' ? href.replace(/\/$/, '') || '/' : href;
const subpath = pathname.match(/[^\/]+/g);
const isInternal = typeof normalizedHref === 'string' && normalizedHref.startsWith('/');
const isExact = isInternal && normalizedHref === pathname;
const isActive = isInternal && (
	isExact || normalizedHref === '/' + (subpath?.[0] || '')
);
---

<a
	href={href}
	class:list={[className, { active: isActive }]}
	aria-current={isActive ? 'page' : undefined}
	{...props}
>
	<slot />
</a>
<style>
	a {
		--nav-highlight: rgb(128 128 128 / 13%);
		--nav-highlight-active: rgb(128 128 128 / 20%);
		--nav-rim: rgb(255 255 255 / 12%);

		position: relative;
		isolation: isolate;
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		padding: 0.25rem 0;
		color: var(--muted-foreground);
		font-size: 0.86rem;
		font-weight: 540;
		text-decoration: none;
	}

	a::before {
		position: absolute;
		inset: 0.2rem -0.55rem;
		z-index: -1;
		border-radius: 999px;
		background: transparent;
		content: '';
		pointer-events: none;
		transform: scale(0.96);
		transition:
			background-color 150ms ease,
			box-shadow 150ms ease,
			transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	a:hover,
	a:focus-visible,
	a.active {
		color: var(--foreground);
	}

	a:hover::before,
	a:focus-visible::before {
		background: var(--nav-highlight);
		box-shadow: inset 0 0 0 0.5px var(--nav-rim);
		transform: scale(1);
	}

	a.active::before {
		background: var(--nav-highlight-active);
		box-shadow:
			inset 0 0 0 0.5px var(--nav-rim),
			0 0.1rem 0.35rem rgb(0 0 0 / 8%);
		transform: scale(1);
	}

	a:active::before {
		transform: scale(0.94);
	}

	@media (max-width: 590px) {
		a::before {
			inset-inline: -0.45rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		a::before,
		a:hover::before,
		a:focus-visible::before,
		a.active::before,
		a:active::before {
			transform: none;
		}
	}
</style>
