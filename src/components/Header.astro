---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header">
	<div class="site-shell header-inner">
		<div class="header-optics" aria-hidden="true">
			<div class="header-glass" data-liquid-glass></div>
		</div>
		<div class="header-rim" aria-hidden="true"></div>
		<div class="header-content">
			<a class="wordmark" href="/" aria-label={`${SITE_TITLE} home`}>shen.zip</a>
			<nav aria-label="Primary navigation" data-primary-nav>
				<span class="nav-pill" data-nav-pill aria-hidden="true"></span>
				<HeaderLink href="/blog">Notes</HeaderLink>
				<HeaderLink href="/about">About me</HeaderLink>
				<HeaderLink href="/contact">Contact</HeaderLink>
			</nav>
		</div>
	</div>
</header>

<script is:inline>
	(() => {
		const header = document.querySelector('.site-header');
		if (!(header instanceof HTMLElement)) return;

		let framePending = false;
		const updateGlass = () => {
			framePending = false;
			header.toggleAttribute('data-scrolled', window.scrollY > header.offsetHeight);
		};
		const scheduleUpdate = () => {
			if (framePending) return;
			framePending = true;
			window.requestAnimationFrame(updateGlass);
		};

		updateGlass();
		window.addEventListener('scroll', scheduleUpdate, { passive: true });

		const nav = header.querySelector('[data-primary-nav]');
		const pill = nav?.querySelector('[data-nav-pill]');
		if (!(nav instanceof HTMLElement) || !(pill instanceof HTMLElement)) return;

		const links = Array.from(nav.querySelectorAll('a')).filter(
			(link) => link instanceof HTMLAnchorElement,
		);
		const activeLink = links.find((link) => link.getAttribute('aria-current') === 'page') ?? null;
		let hoveredLink = null;
		let focusedLink = null;
		let currentLink = activeLink;
		let currentState = 'active';
		let resizeFrame = 0;

		const placePill = (link, state = 'active', instant = false) => {
			currentLink = link;
			currentState = state;

			if (!(link instanceof HTMLAnchorElement)) {
				pill.removeAttribute('data-visible');
				return;
			}

			if (instant) pill.setAttribute('data-instant', '');
			const navRect = nav.getBoundingClientRect();
			const linkRect = link.getBoundingClientRect();
			const rootSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
			const verticalInset = rootSize * 0.2;

			pill.style.setProperty('--nav-pill-x', `${linkRect.left - navRect.left}px`);
			pill.style.setProperty('--nav-pill-y', `${linkRect.top - navRect.top + verticalInset}px`);
			pill.style.setProperty('--nav-pill-width', `${linkRect.width}px`);
			pill.style.setProperty('--nav-pill-height', `${Math.max(0, linkRect.height - verticalInset * 2)}px`);
			pill.dataset.state = state;
			pill.setAttribute('data-visible', '');

			if (instant) {
				void pill.offsetWidth;
				pill.removeAttribute('data-instant');
			}
		};

		const settlePill = () => {
			const previewLink = focusedLink ?? hoveredLink;
			placePill(previewLink ?? activeLink, previewLink ? 'preview' : 'active');
		};

		links.forEach((link) => {
			link.addEventListener('pointerenter', () => {
				hoveredLink = link;
				settlePill();
			});
			link.addEventListener('pointerleave', () => {
				if (hoveredLink === link) hoveredLink = null;
				settlePill();
			});
			link.addEventListener('focusin', () => {
				focusedLink = link;
				settlePill();
			});
			link.addEventListener('focusout', () => {
				window.requestAnimationFrame(() => {
					focusedLink = links.find((candidate) => candidate === document.activeElement) ?? null;
					settlePill();
				});
			});
			link.addEventListener('pointerdown', (event) => {
				if (event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
				placePill(link, 'active');
			});
		});

		const schedulePillLayout = () => {
			if (resizeFrame) return;
			resizeFrame = window.requestAnimationFrame(() => {
				resizeFrame = 0;
				placePill(currentLink, currentState, true);
			});
		};

		placePill(activeLink, 'active', true);
		window.addEventListener('resize', schedulePillLayout, { passive: true });
		if ('ResizeObserver' in window) {
			const navResizeObserver = new ResizeObserver(schedulePillLayout);
			navResizeObserver.observe(nav);
			links.forEach((link) => navResizeObserver.observe(link));
		}
		document.fonts?.ready.then(schedulePillLayout);
	})();
</script>

<script>
	import { createLiquidGlassFilter } from '../utils/liquidGlass';

	const glass = document.querySelector('[data-liquid-glass]');
	const isChromium = /(?:Chrome|Chromium|Edg)\/\d/.test(navigator.userAgent)
		&& !/(?:CriOS|EdgiOS)\//.test(navigator.userAgent);
	const supportsSvgBackdrop = typeof CSS !== 'undefined'
		&& CSS.supports('backdrop-filter', 'url("#test")');

	if (glass instanceof HTMLElement && isChromium && supportsSvgBackdrop) {
		let previousSize = '';
		let resizeFrame = 0;
		const updateRefraction = () => {
			resizeFrame = 0;
			const { width, height } = glass.getBoundingClientRect();
			const roundedWidth = Math.round(width);
			const roundedHeight = Math.round(height);
			const size = `${roundedWidth}x${roundedHeight}`;
			if (size === previousSize || roundedWidth < 1 || roundedHeight < 1) return;

			previousSize = size;
			glass.style.setProperty(
				'--glass-refraction',
				createLiquidGlassFilter({ width: roundedWidth, height: roundedHeight }),
			);
			glass.toggleAttribute('data-refraction-ready', true);
		};
		const scheduleRefraction = () => {
			if (resizeFrame) return;
			resizeFrame = window.requestAnimationFrame(updateRefraction);
		};

		updateRefraction();
		new ResizeObserver(scheduleRefraction).observe(glass);
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding-top: 0.75rem;
	}

	.header-inner {
		--glass-solid: rgb(232 232 232);
		--glass-fill: rgb(128 128 128 / 11%);
		--glass-blur: 2px;
		--glass-fallback-blur: 0.85rem;
		--glass-contrast: 92%;
		--glass-brightness: 108%;
		--glass-inner-band: rgb(255 255 255 / 8%);
		--glass-shadow: rgb(0 0 0 / 12%);
		--glass-shadow-scrolled: rgb(0 0 0 / 17%);

		position: relative;
		isolation: isolate;
		border: 1px solid transparent;
		border-radius: 999px;
		background: transparent;
		background-clip: padding-box;
		box-shadow:
			0 0.65rem 1.75rem var(--glass-shadow),
			0 0.1rem 0.35rem rgb(0 0 0 / 7%);
		transition: border-color 180ms ease, box-shadow 180ms ease;
	}

	.header-content {
		position: relative;
		z-index: 2;
		isolation: isolate;
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		align-items: center;
		justify-content: space-between;
		min-height: 3.6rem;
		padding-inline: 1rem;
	}

	.site-header[data-scrolled] .header-inner {
		--glass-fill: rgb(128 128 128 / 18%);
		--glass-blur: 2.5px;
		--glass-fallback-blur: 0.95rem;
		--glass-contrast: 84%;
		--glass-brightness: 110%;

		box-shadow:
			0 0.75rem 2rem var(--glass-shadow-scrolled),
			0 0.1rem 0.35rem rgb(0 0 0 / 9%);
	}

	.header-optics,
	.header-rim {
		position: absolute;
		inset: 0;
		z-index: 0;
		border-radius: inherit;
		pointer-events: none;
	}

	.header-optics {
		inset: -1px;
		overflow: hidden;
	}

	.header-glass {
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		background: var(--glass-solid);
		transition: background-color 180ms ease;
	}

	.header-rim {
		z-index: 1;
		box-shadow: inset 0 0 0.8rem var(--glass-inner-band);
	}

	@supports ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
		.header-glass {
			background: var(--glass-fill);
			-webkit-backdrop-filter:
				blur(var(--glass-fallback-blur)) grayscale(100%)
				contrast(var(--glass-contrast)) brightness(var(--glass-brightness));
			backdrop-filter:
				blur(var(--glass-fallback-blur)) grayscale(100%)
				contrast(var(--glass-contrast)) brightness(var(--glass-brightness));
		}

		.header-glass[data-refraction-ready] {
			-webkit-backdrop-filter:
				blur(0.5px) var(--glass-refraction) blur(var(--glass-blur))
				grayscale(100%) contrast(var(--glass-contrast))
				brightness(var(--glass-brightness));
			backdrop-filter:
				blur(0.5px) var(--glass-refraction) blur(var(--glass-blur))
				grayscale(100%) contrast(var(--glass-contrast))
				brightness(var(--glass-brightness));
		}
	}

	.wordmark {
		--nav-highlight: rgb(128 128 128 / 13%);
		--nav-rim: rgb(255 255 255 / 12%);

		position: relative;
		z-index: 2;
		isolation: isolate;
		display: inline-flex;
		flex: none;
		align-items: center;
		min-height: 44px;
		color: var(--foreground);
		font-size: 1rem;
		font-weight: 680;
		letter-spacing: -0.035em;
		text-decoration: none;
	}

	.wordmark::before {
		position: absolute;
		inset: 0.2rem -0.55rem;
		z-index: -1;
		border-radius: 999px;
		background: transparent;
		content: '';
		pointer-events: none;
		transform: scale(0.96);
		transition:
			background-color 150ms ease,
			box-shadow 150ms ease,
			transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.wordmark:hover,
	.wordmark:focus-visible {
		color: var(--foreground);
	}

	.wordmark:hover::before,
	.wordmark:focus-visible::before {
		background: var(--nav-highlight);
		box-shadow: inset 0 0 0 0.5px var(--nav-rim);
		transform: scale(1);
	}

	.wordmark:active::before {
		transform: scale(0.94);
	}

	nav {
		position: relative;
		z-index: 2;
		isolation: isolate;
		display: flex;
		flex: 1 1 auto;
		flex-wrap: wrap;
		gap: 0.3rem;
		align-items: center;
		justify-content: flex-end;
		min-width: min(100%, 11rem);
	}

	.nav-pill {
		position: absolute;
		top: 0;
		left: 0;
		z-index: 0;
		width: var(--nav-pill-width, 0);
		height: var(--nav-pill-height, 0);
		border-radius: 999px;
		background: rgb(128 128 128 / 12%);
		box-shadow: inset 0 0 0 0.5px rgb(255 255 255 / 10%);
		opacity: 0;
		pointer-events: none;
		transform: translate3d(var(--nav-pill-x, 0), var(--nav-pill-y, 0), 0);
		transition:
			transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
			width 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
			height 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
			background-color 150ms ease,
			box-shadow 150ms ease,
			opacity 120ms ease;
		will-change: transform, width, height;
	}

	.nav-pill[data-visible] {
		opacity: 1;
		view-transition-name: nav-active-pill;
	}

	.nav-pill[data-state='preview'] {
		background: rgb(128 128 128 / 19%);
		box-shadow:
			inset 0 0 0 0.5px rgb(255 255 255 / 14%),
			0 0.1rem 0.35rem rgb(0 0 0 / 7%);
	}

	.nav-pill[data-instant] {
		transition: none;
	}

	@media (prefers-color-scheme: dark) {
		.header-inner {
			--glass-solid: rgb(28 28 28);
			--glass-fill: rgb(128 128 128 / 13%);
			--glass-blur: 2px;
			--glass-fallback-blur: 0.85rem;
			--glass-contrast: 90%;
			--glass-brightness: 78%;
			--glass-inner-band: rgb(255 255 255 / 5%);
			--glass-shadow: rgb(0 0 0 / 30%);
			--glass-shadow-scrolled: rgb(0 0 0 / 38%);
		}

		.site-header[data-scrolled] .header-inner {
			--glass-fill: rgb(128 128 128 / 19%);
			--glass-blur: 2.5px;
			--glass-fallback-blur: 0.95rem;
			--glass-contrast: 82%;
			--glass-brightness: 74%;
		}
	}

	@media (max-width: 590px) {
		.site-header {
			padding-top: 0.5rem;
		}

		.header-content {
			gap: 0.75rem;
			min-height: 3.35rem;
			padding-inline: 0.75rem;
		}

		.wordmark::before {
			inset-inline: -0.45rem;
		}

		nav {
			gap: 0.1rem;
		}
	}

	@media (prefers-reduced-transparency: reduce) {
		.header-inner {
			border-color: var(--border);
		}

		.header-glass,
		.header-glass[data-refraction-ready] {
			background: var(--glass-solid);
			-webkit-backdrop-filter: none;
			backdrop-filter: none;
		}

		.header-rim {
			display: none;
		}

		.nav-pill {
			background: rgb(128 128 128 / 22%);
		}

		.nav-pill[data-state='preview'] {
			background: rgb(128 128 128 / 30%);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.nav-pill {
			transition: none;
		}

		.wordmark::before,
		.wordmark:hover::before,
		.wordmark:focus-visible::before,
		.wordmark:active::before {
			transform: none;
		}
	}

	@media (forced-colors: active) {
		.header-inner {
			border-color: CanvasText;
			box-shadow: none;
		}

		.header-glass,
		.header-glass[data-refraction-ready] {
			background: Canvas;
			-webkit-backdrop-filter: none;
			backdrop-filter: none;
		}

		.header-rim {
			display: none;
		}

		.nav-pill {
			display: none;
		}
	}
</style>
