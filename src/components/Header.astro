---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="site-header" transition:persist="site-header">
	<div class="site-shell header-inner">
		<div class="header-optics" aria-hidden="true">
			<div class="header-glass" data-liquid-glass></div>
		</div>
		<div class="header-rim" aria-hidden="true"></div>
		<div class="header-content">
			<a class="wordmark" href="/" aria-label={`${SITE_TITLE} home`}>shen.zip</a>
			<div class="header-actions">
				<nav aria-label="Primary navigation" data-primary-nav>
					<span class="nav-pill" data-nav-pill aria-hidden="true"></span>
					<HeaderLink href="/blog">Notes</HeaderLink>
					<HeaderLink href="/about">About me</HeaderLink>
					<HeaderLink href="/contact">Contact</HeaderLink>
				</nav>
				<button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch color theme">
					<svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
						<path d="M20.2 15.4A8.5 8.5 0 0 1 8.6 3.8 8.5 8.5 0 1 0 20.2 15.4Z"></path>
					</svg>
					<svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
						<circle cx="12" cy="12" r="3.75"></circle>
						<path d="M12 2.25v2.1M12 19.65v2.1M2.25 12h2.1M19.65 12h2.1M5.1 5.1l1.5 1.5M17.4 17.4l1.5 1.5M18.9 5.1l-1.5 1.5M6.6 17.4l-1.5 1.5"></path>
					</svg>
				</button>
			</div>
		</div>
	</div>
</header>

<script is:inline>
	(() => {
		const header = document.querySelector('.site-header');
		if (!(header instanceof HTMLElement)) return;
		if (header.dataset.initialized === 'true') return;
		header.dataset.initialized = 'true';

		let framePending = false;
		const updateGlass = () => {
			framePending = false;
			header.toggleAttribute('data-scrolled', window.scrollY > header.offsetHeight);
		};
		const scheduleUpdate = () => {
			if (framePending) return;
			framePending = true;
			window.requestAnimationFrame(updateGlass);
		};

		updateGlass();
		window.addEventListener('scroll', scheduleUpdate, { passive: true });

		const themeToggle = header.querySelector('[data-theme-toggle]');
		if (themeToggle instanceof HTMLButtonElement) {
			const systemTheme = window.matchMedia('(prefers-color-scheme: dark)');
			const currentTheme = () => document.documentElement.dataset.theme
				|| (systemTheme.matches ? 'dark' : 'light');
			const syncThemeToggle = () => {
				const theme = currentTheme();
				const label = `Switch to ${theme === 'dark' ? 'light' : 'dark'} mode`;
				themeToggle.setAttribute('aria-label', label);
				themeToggle.title = label;
				document.querySelector('[data-theme-color]')?.setAttribute(
					'content',
					theme === 'dark' ? '#111211' : '#f7f6f2',
				);
			};

			themeToggle.addEventListener('click', () => {
				const theme = currentTheme() === 'dark' ? 'light' : 'dark';
				document.documentElement.dataset.theme = theme;
				try {
					window.localStorage.setItem('shen.zip-theme', theme);
				} catch {}
				syncThemeToggle();
				window.dispatchEvent(new CustomEvent('shen:theme-change', { detail: { theme } }));
			});
			systemTheme.addEventListener('change', () => {
				if (document.documentElement.dataset.theme) return;
				syncThemeToggle();
				window.dispatchEvent(new CustomEvent('shen:theme-change', {
					detail: { theme: currentTheme() },
				}));
			});
			syncThemeToggle();
		}

		const nav = header.querySelector('[data-primary-nav]');
		const pill = nav?.querySelector('[data-nav-pill]');
		if (!(nav instanceof HTMLElement) || !(pill instanceof HTMLElement)) return;

		const links = Array.from(nav.querySelectorAll('a')).filter(
			(link) => link instanceof HTMLAnchorElement,
		);
		let activeLink = links.find((link) => link.getAttribute('aria-current') === 'page') ?? null;
		let hoveredLink = null;
		let focusedLink = null;
		let currentLink = activeLink;
		let currentState = 'active';
		let resizeFrame = 0;

		const placePill = (link, state = 'active', instant = false) => {
			currentLink = link;
			currentState = state;

			if (!(link instanceof HTMLAnchorElement)) {
				pill.removeAttribute('data-visible');
				return;
			}

			if (instant) pill.setAttribute('data-instant', '');
			const navRect = nav.getBoundingClientRect();
			const linkRect = link.getBoundingClientRect();
			const rootSize = Number.parseFloat(getComputedStyle(document.documentElement).fontSize) || 16;
			const verticalInset = rootSize * 0.2;

			pill.style.setProperty('--nav-pill-x', `${linkRect.left - navRect.left}px`);
			pill.style.setProperty('--nav-pill-y', `${linkRect.top - navRect.top + verticalInset}px`);
			pill.style.setProperty('--nav-pill-width', `${linkRect.width}px`);
			pill.style.setProperty('--nav-pill-height', `${Math.max(0, linkRect.height - verticalInset * 2)}px`);
			pill.dataset.state = state;
			pill.setAttribute('data-visible', '');

			if (instant) {
				void pill.offsetWidth;
				pill.removeAttribute('data-instant');
			}
		};

		const settlePill = () => {
			const previewLink = focusedLink ?? hoveredLink;
			placePill(previewLink ?? activeLink, previewLink ? 'preview' : 'active');
		};
		const syncActiveLink = (nextPath = window.location.pathname, instant = false) => {
			const pathname = nextPath.replace(/\/$/, '') || '/';
			activeLink = links.find((link) => {
				const linkPath = new URL(link.href, window.location.href).pathname.replace(/\/$/, '') || '/';
				return linkPath === pathname || (linkPath !== '/' && pathname.startsWith(`${linkPath}/`));
			}) ?? null;

			links.forEach((link) => {
				const isActive = link === activeLink;
				link.classList.toggle('active', isActive);
				if (isActive) link.setAttribute('aria-current', 'page');
				else link.removeAttribute('aria-current');
			});
			hoveredLink = null;
			focusedLink = null;
			placePill(activeLink, 'active', instant);
		};

		links.forEach((link) => {
			link.addEventListener('pointerenter', (event) => {
				if (event.pointerType === 'touch') return;
				hoveredLink = link;
				settlePill();
			});
			link.addEventListener('pointerleave', (event) => {
				if (event.pointerType === 'touch') return;
				if (hoveredLink === link) hoveredLink = null;
				settlePill();
			});
			link.addEventListener('focusin', () => {
				focusedLink = link;
				settlePill();
			});
			link.addEventListener('focusout', () => {
				window.requestAnimationFrame(() => {
					focusedLink = links.find((candidate) => candidate === document.activeElement) ?? null;
					settlePill();
				});
			});
			link.addEventListener('pointerdown', (event) => {
				if (event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
				placePill(link, 'active');
			});
		});

		const schedulePillLayout = () => {
			if (resizeFrame) return;
			resizeFrame = window.requestAnimationFrame(() => {
				resizeFrame = 0;
				placePill(currentLink, currentState, true);
			});
		};

		syncActiveLink(window.location.pathname, true);
		document.addEventListener('astro:before-preparation', (event) => {
			const nextPath = event instanceof Event && 'to' in event && event.to instanceof URL
				? event.to.pathname
				: window.location.pathname;
			if (nextPath === window.location.pathname) return;

			syncActiveLink(nextPath);
			if (
				window.matchMedia('(prefers-reduced-motion: reduce)').matches
				|| !('loader' in event)
				|| typeof event.loader !== 'function'
			) return;

			const loadPage = event.loader;
			event.loader = async () => {
				await Promise.all([
					loadPage(),
					new Promise((resolve) => window.setTimeout(resolve, 240)),
				]);
			};
		});
		document.addEventListener('astro:before-swap', (event) => {
			const nextPath = event instanceof Event && 'to' in event && event.to instanceof URL
				? event.to.pathname
				: window.location.pathname;
			syncActiveLink(nextPath);
		});
		document.addEventListener('astro:page-load', () => syncActiveLink());
		window.addEventListener('resize', schedulePillLayout, { passive: true });
		if ('ResizeObserver' in window) {
			const navResizeObserver = new ResizeObserver(schedulePillLayout);
			navResizeObserver.observe(nav);
			links.forEach((link) => navResizeObserver.observe(link));
		}
		document.fonts?.ready.then(schedulePillLayout);
	})();
</script>

<script>
	import { createLiquidGlassFilter } from '../utils/liquidGlass';

	const glass = document.querySelector('[data-liquid-glass]');
	const isChromium = /(?:Chrome|Chromium|Edg)\/\d/.test(navigator.userAgent)
		&& !/(?:CriOS|EdgiOS)\//.test(navigator.userAgent);
	const supportsSvgBackdrop = typeof CSS !== 'undefined'
		&& CSS.supports('backdrop-filter', 'url("#test")');

	if (glass instanceof HTMLElement && isChromium && supportsSvgBackdrop) {
		let previousSize = '';
		let resizeFrame = 0;
		const updateRefraction = () => {
			resizeFrame = 0;
			const { width, height } = glass.getBoundingClientRect();
			const roundedWidth = Math.round(width);
			const roundedHeight = Math.round(height);
			const size = `${roundedWidth}x${roundedHeight}`;
			if (size === previousSize || roundedWidth < 1 || roundedHeight < 1) return;

			previousSize = size;
			glass.style.setProperty(
				'--glass-refraction',
				createLiquidGlassFilter({ width: roundedWidth, height: roundedHeight }),
			);
			glass.toggleAttribute('data-refraction-ready', true);
		};
		const scheduleRefraction = () => {
			if (resizeFrame) return;
			resizeFrame = window.requestAnimationFrame(updateRefraction);
		};

		updateRefraction();
		new ResizeObserver(scheduleRefraction).observe(glass);
	}
</script>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding-top: 0.75rem;
	}

	.header-inner {
		--glass-solid: rgb(232 232 232);
		--glass-fill: rgb(128 128 128 / 8%);
		--glass-blur: 2px;
		--glass-fallback-blur: 0.85rem;
		--glass-contrast: 92%;
		--glass-brightness: 108%;
		--glass-inner-band: rgb(255 255 255 / 8%);
		--glass-shadow: rgb(0 0 0 / 12%);
		--glass-shadow-scrolled: rgb(0 0 0 / 17%);

		position: relative;
		isolation: isolate;
		border: 1px solid transparent;
		border-radius: 999px;
		background: transparent;
		background-clip: padding-box;
		box-shadow:
			0 0.65rem 1.75rem var(--glass-shadow),
			0 0.1rem 0.35rem rgb(0 0 0 / 7%);
		transition: border-color 180ms ease, box-shadow 180ms ease;
	}

	.header-content {
		position: relative;
		z-index: 2;
		isolation: isolate;
		display: flex;
		flex-wrap: wrap;
		gap: 1.5rem;
		align-items: center;
		justify-content: space-between;
		min-height: 3.6rem;
		padding-inline: 1rem;
	}

	.site-header[data-scrolled] .header-inner {
		--glass-fill: rgb(128 128 128 / 15%);
		--glass-blur: 2.5px;
		--glass-fallback-blur: 0.95rem;
		--glass-contrast: 84%;
		--glass-brightness: 110%;

		box-shadow:
			0 0.75rem 2rem var(--glass-shadow-scrolled),
			0 0.1rem 0.35rem rgb(0 0 0 / 9%);
	}

	.header-optics,
	.header-rim {
		position: absolute;
		inset: 0;
		z-index: 0;
		border-radius: inherit;
		pointer-events: none;
	}

	.header-optics {
		inset: -1px;
		overflow: hidden;
	}

	.header-glass {
		position: absolute;
		inset: -1px;
		border-radius: inherit;
		background: var(--glass-solid);
		transition: background-color 180ms ease;
	}

	.header-rim {
		z-index: 1;
		box-shadow: inset 0 0 0.8rem var(--glass-inner-band);
	}

	@supports ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
		.header-glass {
			background: var(--glass-fill);
			-webkit-backdrop-filter:
				blur(var(--glass-fallback-blur)) grayscale(100%)
				contrast(var(--glass-contrast)) brightness(var(--glass-brightness));
			backdrop-filter:
				blur(var(--glass-fallback-blur)) grayscale(100%)
				contrast(var(--glass-contrast)) brightness(var(--glass-brightness));
		}

		.header-glass[data-refraction-ready] {
			-webkit-backdrop-filter:
				blur(0.5px) var(--glass-refraction) blur(var(--glass-blur))
				grayscale(100%) contrast(var(--glass-contrast))
				brightness(var(--glass-brightness));
			backdrop-filter:
				blur(0.5px) var(--glass-refraction) blur(var(--glass-blur))
				grayscale(100%) contrast(var(--glass-contrast))
				brightness(var(--glass-brightness));
		}
	}

	.wordmark {
		--nav-highlight: rgb(128 128 128 / 13%);
		--nav-rim: rgb(255 255 255 / 12%);

		position: relative;
		z-index: 2;
		isolation: isolate;
		display: inline-flex;
		flex: none;
		align-items: center;
		min-height: 44px;
		color: var(--foreground);
		font-size: 1rem;
		font-weight: 680;
		letter-spacing: -0.035em;
		text-decoration: none;
	}

	.wordmark::before {
		position: absolute;
		inset: 0.2rem -0.55rem;
		z-index: -1;
		border-radius: 999px;
		background: var(--nav-highlight);
		box-shadow: inset 0 0 0 0.5px var(--nav-rim);
		content: '';
		opacity: 0;
		pointer-events: none;
		transform: scale(0.96);
		transition:
			opacity 150ms ease,
			transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.wordmark:focus-visible {
		color: var(--foreground);
	}

	.wordmark:focus-visible::before {
		opacity: 1;
		transform: scale(1);
	}

	@media (hover: hover) and (pointer: fine) {
		.wordmark:hover {
			color: var(--foreground);
		}

		.wordmark:hover::before {
			opacity: 1;
			transform: scale(1);
		}
	}

	.wordmark:active::before {
		opacity: 1;
		transform: scale(0.94);
	}

	.header-actions {
		position: relative;
		z-index: 2;
		display: flex;
		flex: 1 1 auto;
		gap: 0.45rem;
		align-items: center;
		justify-content: flex-end;
		min-width: min(100%, 14rem);
	}

	nav {
		position: relative;
		isolation: isolate;
		display: flex;
		flex: 0 1 auto;
		flex-wrap: wrap;
		gap: 0.3rem;
		align-items: center;
		justify-content: flex-end;
		min-width: min(100%, 11rem);
	}

	.nav-pill {
		position: absolute;
		top: 0;
		left: 0;
		z-index: 0;
		width: var(--nav-pill-width, 0);
		height: var(--nav-pill-height, 0);
		border-radius: 999px;
		background: rgb(128 128 128 / 12%);
		box-shadow: inset 0 0 0 0.5px rgb(255 255 255 / 10%);
		opacity: 0;
		pointer-events: none;
		transform: translate3d(var(--nav-pill-x, 0), var(--nav-pill-y, 0), 0);
		transition:
			transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
			width 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
			height 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
			background-color 150ms ease,
			box-shadow 150ms ease,
			opacity 120ms ease;
		will-change: transform, width, height;
	}

	.nav-pill[data-visible] {
		opacity: 1;
	}

	.nav-pill[data-state='preview'] {
		background: rgb(128 128 128 / 19%);
		box-shadow:
			inset 0 0 0 0.5px rgb(255 255 255 / 14%),
			0 0.1rem 0.35rem rgb(0 0 0 / 7%);
	}

	.nav-pill[data-instant] {
		transition: none;
	}

	.theme-toggle {
		position: relative;
		isolation: isolate;
		display: inline-grid;
		flex: 0 0 44px;
		place-items: center;
		width: 44px;
		height: 44px;
		padding: 0;
		border: 0;
		border-radius: 999px;
		background: transparent;
		box-shadow: none;
		color: var(--muted-foreground);
		cursor: pointer;
		transition:
			color 150ms ease,
			transform 180ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.theme-toggle::before {
		position: absolute;
		inset: 0.2rem;
		z-index: -1;
		border-radius: inherit;
		background: rgb(128 128 128 / 13%);
		box-shadow: inset 0 0 0 0.5px rgb(255 255 255 / 12%);
		content: '';
		opacity: 0;
		pointer-events: none;
		transition: opacity 150ms ease;
	}

	.theme-toggle:focus-visible {
		color: var(--foreground);
	}

	.theme-toggle:focus-visible::before {
		opacity: 1;
	}

	@media (hover: hover) and (pointer: fine) {
		.theme-toggle:hover {
			color: var(--foreground);
		}

		.theme-toggle:hover::before {
			opacity: 1;
		}
	}

	.theme-toggle:active {
		color: var(--foreground);
		transform: scale(0.94);
	}

	.theme-toggle:active::before {
		opacity: 1;
	}

	@media (hover: none) and (pointer: coarse) {
		.wordmark::before,
		.theme-toggle::before {
			transition: none;
		}
	}

	.theme-icon {
		width: 1.05rem;
		height: 1.05rem;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.7;
	}

	.theme-icon-sun {
		display: none;
	}

	@media (prefers-color-scheme: dark) {
		:global(html:not([data-theme])) .header-inner {
			--glass-solid: rgb(28 28 28);
			--glass-fill: rgb(128 128 128 / 10%);
			--glass-blur: 2px;
			--glass-fallback-blur: 0.85rem;
			--glass-contrast: 90%;
			--glass-brightness: 78%;
			--glass-inner-band: rgb(255 255 255 / 5%);
			--glass-shadow: rgb(0 0 0 / 30%);
			--glass-shadow-scrolled: rgb(0 0 0 / 38%);
		}

		:global(html:not([data-theme])) .site-header[data-scrolled] .header-inner {
			--glass-fill: rgb(128 128 128 / 16%);
			--glass-blur: 2.5px;
			--glass-fallback-blur: 0.95rem;
			--glass-contrast: 82%;
			--glass-brightness: 74%;
		}

		:global(html:not([data-theme])) .theme-icon-moon {
			display: none;
		}

		:global(html:not([data-theme])) .theme-icon-sun {
			display: block;
		}
	}

	:global(html[data-theme='dark']) .header-inner {
		--glass-solid: rgb(28 28 28);
		--glass-fill: rgb(128 128 128 / 10%);
		--glass-blur: 2px;
		--glass-fallback-blur: 0.85rem;
		--glass-contrast: 90%;
		--glass-brightness: 78%;
		--glass-inner-band: rgb(255 255 255 / 5%);
		--glass-shadow: rgb(0 0 0 / 30%);
		--glass-shadow-scrolled: rgb(0 0 0 / 38%);
	}

	:global(html[data-theme='dark']) .site-header[data-scrolled] .header-inner {
		--glass-fill: rgb(128 128 128 / 16%);
		--glass-blur: 2.5px;
		--glass-fallback-blur: 0.95rem;
		--glass-contrast: 82%;
		--glass-brightness: 74%;
	}

	:global(html[data-theme='dark']) .theme-icon-moon {
		display: none;
	}

	:global(html[data-theme='dark']) .theme-icon-sun {
		display: block;
	}

	/* WebKit drops SVG URL filters from backdrop-filter, so iOS uses a
	   neutral native blur with a thin Retina rim instead of fake color. */
	:global(html[data-ios-webkit]) .header-inner {
		--glass-fill: rgb(128 128 128 / 5%);
		--glass-fallback-blur: 0.5rem;
		--glass-contrast: 97%;
		--glass-brightness: 103%;
		--glass-inner-band: transparent;
		--glass-shadow: rgb(0 0 0 / 10%);
		--glass-shadow-scrolled: rgb(0 0 0 / 15%);
	}

	:global(html[data-ios-webkit]) .site-header[data-scrolled] .header-inner {
		--glass-fill: rgb(128 128 128 / 8%);
		--glass-fallback-blur: 0.625rem;
		--glass-contrast: 95%;
		--glass-brightness: 101%;
	}

	:global(html[data-ios-webkit]) .header-rim {
		border: 0.5px solid rgb(255 255 255 / 14%);
		box-shadow: inset 0 1px 0 rgb(255 255 255 / 16%);
	}

	@media (prefers-color-scheme: dark) {
		:global(html[data-ios-webkit]:not([data-theme])) .header-inner {
			--glass-fill: rgb(128 128 128 / 6%);
			--glass-contrast: 97%;
			--glass-brightness: 94%;
			--glass-shadow: rgb(0 0 0 / 18%);
			--glass-shadow-scrolled: rgb(0 0 0 / 24%);
		}

		:global(html[data-ios-webkit]:not([data-theme])) .site-header[data-scrolled] .header-inner {
			--glass-fill: rgb(128 128 128 / 9%);
			--glass-contrast: 95%;
			--glass-brightness: 92%;
		}
	}

	:global(html[data-ios-webkit][data-theme='dark']) .header-inner {
		--glass-fill: rgb(128 128 128 / 6%);
		--glass-contrast: 97%;
		--glass-brightness: 94%;
		--glass-shadow: rgb(0 0 0 / 18%);
		--glass-shadow-scrolled: rgb(0 0 0 / 24%);
	}

	:global(html[data-ios-webkit][data-theme='dark']) .site-header[data-scrolled] .header-inner {
		--glass-fill: rgb(128 128 128 / 9%);
		--glass-contrast: 95%;
		--glass-brightness: 92%;
	}

	@media (max-width: 590px) {
		.site-header {
			padding-top: 0.5rem;
		}

		.header-content {
			gap: 0.75rem;
			min-height: 3.35rem;
			padding-inline: 0.75rem;
		}

		:global(html[data-ios-webkit]) .header-content {
			padding-inline: 1rem;
		}

		.wordmark::before {
			inset-inline: -0.45rem;
		}

		nav {
			gap: 0.1rem;
		}
	}

	@media (prefers-reduced-transparency: reduce) {
		.header-inner {
			border-color: var(--border);
		}

		.header-glass,
		.header-glass[data-refraction-ready] {
			background: var(--glass-solid);
			-webkit-backdrop-filter: none;
			backdrop-filter: none;
